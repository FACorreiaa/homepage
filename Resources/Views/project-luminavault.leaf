#extend("base"):
  #export("body"):
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap">

    <div class="lv">
      <!-- ambient backdrop -->
      <div class="lv-aurora" aria-hidden="true"></div>
      <div class="lv-grid" aria-hidden="true"></div>

      <main class="lv-main">
        <div class="lv-wrap">

          <nav aria-label="Breadcrumb" class="lv-breadcrumb">
            <a href="/projects" class="lv-back">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
              All projects
            </a>
          </nav>

          <!-- HERO -->
          <section class="lv-hero" data-reveal>
            <p class="lv-eyebrow">#(eyebrow)</p>
            <h1 class="lv-wordmark"><span class="lv-w1">Lumina</span><span class="lv-w2">Vault</span></h1>
            <p class="lv-tagline">#(tagline)</p>
            <p class="lv-lede">#(lede)</p>

            <div class="lv-cta">
              #if(hasAppStoreUrl):
                <a href="#(appStoreUrl)" class="lv-store" target="_blank" rel="noopener noreferrer" aria-label="Download on the App Store">
                  <svg class="lv-apple" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M16.36 1.43c.05 1.02-.36 2.02-1 2.77-.66.77-1.74 1.36-2.79 1.28-.07-1 .42-2.04 1.04-2.74.69-.79 1.86-1.36 2.75-1.31zM19.6 17.3c-.5 1.16-.74 1.68-1.39 2.71-.9 1.43-2.18 3.22-3.76 3.23-1.4.02-1.76-.91-3.66-.9-1.9.01-2.3.92-3.7.9-1.58-.02-2.79-1.63-3.7-3.06C1.2 16.2.94 11.43 2.5 8.9c1.1-1.78 2.84-2.83 4.48-2.83 1.66 0 2.71.92 4.08.92 1.33 0 2.14-.92 4.07-.92 1.46 0 3.01.8 4.11 2.18-3.61 1.98-3.02 7.14.36 9.05z"></path></svg>
                  <span class="lv-store__txt"><small>Download on the</small><strong>App Store</strong></span>
                </a>
              #else:
                <span class="lv-store is-soon" aria-disabled="true">
                  <svg class="lv-apple" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M16.36 1.43c.05 1.02-.36 2.02-1 2.77-.66.77-1.74 1.36-2.79 1.28-.07-1 .42-2.04 1.04-2.74.69-.79 1.86-1.36 2.75-1.31zM19.6 17.3c-.5 1.16-.74 1.68-1.39 2.71-.9 1.43-2.18 3.22-3.76 3.23-1.4.02-1.76-.91-3.66-.9-1.9.01-2.3.92-3.7.9-1.58-.02-2.79-1.63-3.7-3.06C1.2 16.2.94 11.43 2.5 8.9c1.1-1.78 2.84-2.83 4.48-2.83 1.66 0 2.71.92 4.08.92 1.33 0 2.14-.92 4.07-.92 1.46 0 3.01.8 4.11 2.18-3.61 1.98-3.02 7.14.36 9.05z"></path></svg>
                  <span class="lv-store__txt"><small>Coming soon to the</small><strong>App Store</strong></span>
                </span>
              #endif
              <a href="/book-call" class="lv-ghost">Book a call</a>
            </div>

            <!-- device mockup -->
            <div class="lv-device" data-reveal>
              <div class="lv-device__glow" aria-hidden="true"></div>
              <div class="lv-phone">
                <span class="lv-phone__notch" aria-hidden="true"></span>
                <div class="lv-phone__screen">
                  <img src="#(sceneAsset)" alt="LuminaVault app — Lumina surfacing your memories" loading="eager">
                </div>
              </div>
            </div>
          </section>

          <!-- PILLARS -->
          <section class="lv-pillars" data-reveal>
            <article class="lv-pillar">
              <span class="lv-pillar__ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/></svg>
              </span>
              <h3>Effortless capture</h3>
              <p>Screenshots, photos, locations, HealthKit, links, voice notes — all in seconds, all clean Markdown.</p>
            </article>
            <article class="lv-pillar">
              <span class="lv-pillar__ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m7 8-4 4 4 4"/><path d="m17 8 4 4-4 4"/><path d="m14 4-4 16"/></svg>
              </span>
              <h3>kb-compile</h3>
              <p>One command turns raw notes into a queryable, self-learning wiki with pgvector semantic search.</p>
            </article>
            <article class="lv-pillar">
              <span class="lv-pillar__ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
              </span>
              <h3>Privacy first</h3>
              <p>Self-hosted, per-tenant vaults, JWT auth, BYO LLM key. Your data never leaves your infrastructure.</p>
            </article>
          </section>

          <!-- HOW IT WORKS -->
          <section class="lv-steps" data-reveal>
            <h2 class="lv-h2">How it works</h2>
            <ol class="lv-steps__list">
              #for(step in steps):
                <li class="lv-step">
                  <span class="lv-step__num">#(step.num)</span>
                  <div>
                    <h3>#(step.title)</h3>
                    <p>#(step.body)</p>
                  </div>
                </li>
              #endfor
            </ol>
          </section>

          <!-- STORY -->
          <section class="lv-prose" data-reveal>
            #for(paragraph in longDescription):
              <p>#(paragraph)</p>
            #endfor
          </section>

          <!-- FEATURES -->
          <section class="lv-features" data-reveal>
            <h2 class="lv-h2">Everything inside</h2>
            <div class="lv-features__grid">
              #for(feature in features):
                <article class="lv-feature">
                  <h3>#(feature.title)</h3>
                  <p>#(feature.body)</p>
                </article>
              #endfor
            </div>
          </section>

          <!-- TECH -->
          <section class="lv-tech" data-reveal>
            <h2 class="lv-h2">Built with</h2>
            <ul class="lv-tech__list" role="list">
              #for(tech in techStack):
                <li><span class="lv-pill">#(tech)</span></li>
              #endfor
            </ul>
            #if(backendNote):
              <p class="lv-note">#(backendNote)</p>
            #endif
          </section>

          <!-- BOTTOM CTA -->
          <section class="lv-cta-bottom" data-reveal>
            <div class="lv-cta-card">
              <span class="lv-cta-card__spark" aria-hidden="true"></span>
              <h2>A second brain you actually own.</h2>
              <p>I design and ship privacy-first iOS apps and self-hosted backends, end to end. Let's build yours.</p>
              <div class="lv-cta-card__row">
                <a href="/book-call" class="lv-ghost lv-ghost--solid">Book a call</a>
                <a href="/proposal" class="lv-ghost">Request proposal</a>
              </div>
            </div>
          </section>

        </div>
      </main>
    </div>
  #endexport
#endextend
