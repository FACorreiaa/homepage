*.sqlite
db.sqlite

# Tailwind binary (downloaded during build)
tailwindcss

# Generated CSS (rebuilt during docker build)
Public/css/output.css

# Profiling
default.profraw

# Node (if any)
node_modules/

# Test artifacts
Tests/
